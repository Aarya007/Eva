# Supabase → Project Settings → API → JWT Secret (not the anon key).
# Must match the JWT Secret in the dashboard exactly (HS256 decode in app/core/auth.py).
# Use KEY=value with no spaces around "=" so python-dotenv loads reliably.
SUPABASE_JWT_SECRET=

# Both must be non-empty for Supabase persistence. If either is missing, the API still runs
# but profile data is kept only in process memory (lost on restart). Restart the server after edits.
# Same project URL as in the Supabase dashboard (not the VITE_ prefix — this is SUPABASE_URL).
SUPABASE_URL=

# Supabase → Project Settings → API: service_role key (server only; never in frontend).
# Used to persist eva_user_state + eva_onboarding. Create tables via SQL below.
SUPABASE_SERVICE_ROLE_KEY=

# Dashboard → SQL → New query: run in order if tables are missing —
#   1) supabase/eva_user_state.sql
#   2) supabase/eva_onboarding.sql
#   3) supabase/eva_plans.sql (diet_plans + workout_plans)
# Backend uses the service_role key over PostgREST; it bypasses RLS. Anon key is not used here.

# Google AI Studio / Gemini API key for diet and workout LLM calls (app/services/llm.py, app/core/config.py).
GEMINI_API_KEY_1=

# 1 = print Supabase REST debug (USER_ID, URL, PAYLOAD summary, status, response) to stdout.
# EVA_DEBUG_SUPABASE=1

# 1 = print auth + memory traces (user_id, keys) to stdout; turn off in production.
# When enabled, get_current_user logs:
#   AUTH_HEADER present= / starts_with_Bearer=
#   TOKEN len= ...last4 (never full JWT)
#   DECODED_USER sub="<uuid>" (or error type on failure)
# Without a valid Bearer token, protected routes return 401 (no anonymous user).
# EVA_DEBUG_AUTH=1
