# Supabase → Project Settings → API → JWT Secret (not the anon key).
# Must match the JWT Secret in the dashboard exactly (HS256 decode in app/core/auth.py).
SUPABASE_JWT_SECRET=

# Supabase → Project Settings → API: Project URL and service_role key (server only; never in frontend).
# Used to persist eva_user_state (onboarding memory). Create table via supabase/eva_user_state.sql
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 1 = print auth + memory traces (user_id, keys) to stdout; turn off in production.
# EVA_DEBUG_AUTH=1
