# Set to "true" to show sample-label dashboard chrome (see docs/dashboard-data.md)
VITE_USE_MOCK_DASHBOARD=false

# Required for login / signup (Supabase → Project Settings → API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional. Override OAuth return URL if it cannot be auto-detected (defaults to current browser origin).
# Must be listed under Supabase → Auth → URL Configuration → Redirect URLs (e.g. http://localhost:3000/** )
# VITE_AUTH_REDIRECT_URL=http://localhost:3000/
